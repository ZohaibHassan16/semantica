    "vendor_penalty_check":     {"metric": "refund_rate",              "condition": ">=", "value": 0.08},
    "quality_escalation":       {"metric": "refund_rate",              "condition": ">=", "value": 0.10},
    "fulfillment_capacity_check": {"metric": "order_count",           "condition": ">=", "value": 500},
