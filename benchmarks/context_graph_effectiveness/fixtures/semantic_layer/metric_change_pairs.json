    "ltv_threshold_approval":   {"metric": "customer_lifetime_value",  "condition": ">=", "value": 500},
    "segment_upgrade":          {"metric": "customer_lifetime_value",  "condition": ">=", "value": 1000},
    "order_count_check":        {"metric": "order_count",              "condition": ">=", "value": 100},
    "refund_policy":            {"metric": "refund_rate",              "condition": "<=", "value": 0.05},
    "retention_campaign_trigger": {"metric": "churn_rate",            "condition": ">=", "value": 0.08},
    "at_risk_flag":             {"metric": "churn_rate",               "condition": ">=", "value": 0.12},
    "upsell_trigger":           {"metric": "average_order_value",      "condition": ">=", "value": 75},
    "vip_threshold":            {"metric": "average_order_value",      "condition": ">=", "value": 150},
