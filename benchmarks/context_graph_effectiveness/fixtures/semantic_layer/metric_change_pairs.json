{
  "description": "Before/after metric definition change pairs with gold impact labels. Used for Track 24 — Governance Impact & Change Propagation.",
  "records": [
    {
      "id": "mc001",
      "metric_name": "total_revenue",
      "version_before": {
        "expression": "sum(amount)",
        "filters": [],
        "grain": "order_id"
      },
      "version_after": {
        "expression": "sum(amount * (1 - discount_rate))",
        "filters": [{"field": "status", "operator": "=", "value": "completed"}],
        "grain": "order_id"
      },
      "change_type": "expression_and_filter",
      "affected_decisions": ["approve_deal_q1", "revenue_target_check", "commission_calc"],
      "unaffected_decisions": ["churn_policy_check", "new_customer_bonus"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    },
    {
      "id": "mc002",
      "metric_name": "customer_lifetime_value",
      "version_before": {
        "expression": "sum(amount) / count(distinct customer_id)",
        "grain": "customer_id",
        "time_window": null
      },
      "version_after": {
        "expression": "sum(amount) / count(distinct customer_id)",
        "grain": "customer_id",
        "time_window": "365_days"
      },
      "change_type": "time_window_added",
      "affected_decisions": ["ltv_threshold_approval", "segment_upgrade"],
      "unaffected_decisions": ["order_count_check", "refund_policy"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    },
    {
      "id": "mc003",
      "metric_name": "churn_rate",
      "version_before": {
        "expression": "count(churned_customers) / count(distinct customer_id)",
        "churn_window_days": 90
      },
      "version_after": {
        "expression": "count(churned_customers) / count(distinct customer_id)",
        "churn_window_days": 60
      },
      "change_type": "window_tightened",
      "affected_decisions": ["retention_campaign_trigger", "at_risk_flag", "churn_policy_check"],
      "unaffected_decisions": ["revenue_target_check", "commission_calc"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    },
    {
      "id": "mc004",
      "metric_name": "average_order_value",
      "version_before": {
        "expression": "sum(amount) / count(distinct order_id)",
        "filters": [{"field": "status", "operator": "=", "value": "completed"}]
      },
      "version_after": {
        "expression": "sum(amount) / count(distinct order_id)",
        "filters": [
          {"field": "status", "operator": "=", "value": "completed"},
          {"field": "amount", "operator": ">", "value": 10}
        ]
      },
      "change_type": "filter_added",
      "affected_decisions": ["upsell_trigger", "vip_threshold"],
      "unaffected_decisions": ["churn_policy_check", "new_customer_bonus"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    },
    {
      "id": "mc005",
      "metric_name": "ltv_cac_ratio",
      "version_before": {
        "viability_threshold": 3.0,
        "expression": "customer_lifetime_value / customer_acquisition_cost"
      },
      "version_after": {
        "viability_threshold": 3.5,
        "expression": "customer_lifetime_value / customer_acquisition_cost"
      },
      "change_type": "threshold_raised",
      "affected_decisions": ["channel_investment_approval", "budget_allocation"],
      "unaffected_decisions": ["order_count_check", "refund_policy", "churn_policy_check"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    },
    {
      "id": "mc006",
      "metric_name": "new_customer_count",
      "version_before": {
        "expression": "count(distinct customer_id) filter (where is_first_order = true)",
        "grain": "customer_id"
      },
      "version_after": {
        "expression": "count(distinct customer_id) filter (where is_first_order = true and acquisition_channel != 'internal')",
        "grain": "customer_id"
      },
      "change_type": "filter_exclusion_added",
      "affected_decisions": ["growth_kpi_check", "acquisition_bonus", "new_customer_bonus"],
      "unaffected_decisions": ["revenue_target_check", "ltv_threshold_approval"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    },
    {
      "id": "mc007",
      "metric_name": "refund_rate",
      "version_before": {
        "expression": "count(refunded_orders) / count(distinct order_id)",
        "dimensions": ["region", "product_category"]
      },
      "version_after": {
        "expression": "sum(refund_amount) / sum(order_amount)",
        "dimensions": ["region", "product_category"]
      },
      "change_type": "expression_restatement",
      "affected_decisions": ["vendor_penalty_check", "quality_escalation", "refund_policy"],
      "unaffected_decisions": ["new_customer_bonus", "segment_upgrade"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    },
    {
      "id": "mc008",
      "metric_name": "order_count",
      "version_before": {
        "expression": "count(distinct order_id)",
        "filters": [{"field": "status", "operator": "=", "value": "completed"}]
      },
      "version_after": {
        "expression": "count(distinct order_id)",
        "filters": [
          {"field": "status", "operator": "in", "value": ["completed", "shipped"]}
        ]
      },
      "change_type": "filter_broadened",
      "affected_decisions": ["fulfillment_capacity_check", "ops_bonus", "order_count_check"],
      "unaffected_decisions": ["churn_policy_check", "ltv_threshold_approval"],
      "expected_impact_score": 1.0,
      "expected_drift_decisions": []
    }
  ],
