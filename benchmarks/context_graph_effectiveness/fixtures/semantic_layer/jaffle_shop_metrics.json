{
  "description": "Jaffle Shop governed metric definitions (dbt Semantic Layer / MetricFlow format). Used for Track 21 — Semantic Metric Exactness.",
  "source": "dbt-labs/jaffle_shop + dbt-labs/jaffle-sl-template (open examples)",
  "metrics": [
    {
      "name": "total_revenue",
      "label": "Total Revenue",
      "type": "simple",
      "description": "Sum of all completed order amounts including tax",
      "expression": "sum(amount)",
      "grain": "order_id",
      "dimensions": ["customer_segment", "region", "order_date"],
      "filters": [{"field": "status", "operator": "=", "value": "completed"}],
      "aliases": ["revenue", "total sales", "gross revenue"]
    },
    {
      "name": "order_count",
      "label": "Order Count",
      "type": "simple",
      "description": "Number of distinct completed orders",
      "expression": "count(distinct order_id)",
      "grain": "order_id",
      "dimensions": ["customer_segment", "region", "order_date", "payment_method"],
      "filters": [{"field": "status", "operator": "=", "value": "completed"}],
      "aliases": ["orders", "num orders", "number of orders"]
    },
    {
      "name": "customer_lifetime_value",
      "label": "Customer Lifetime Value",
      "type": "derived",
      "description": "Total revenue attributable to a customer over their full relationship",
      "expression": "sum(amount) / count(distinct customer_id)",
      "grain": "customer_id",
      "dimensions": ["customer_segment", "region", "acquisition_channel"],
      "filters": [{"field": "status", "operator": "=", "value": "completed"}],
      "aliases": ["LTV", "CLV", "lifetime value", "customer value"]
    },
    {
      "name": "average_order_value",
      "label": "Average Order Value",
      "type": "derived",
      "description": "Mean value of completed orders (total_revenue / order_count)",
      "expression": "sum(amount) / count(distinct order_id)",
      "grain": "order_id",
      "dimensions": ["customer_segment", "region", "order_date"],
      "filters": [{"field": "status", "operator": "=", "value": "completed"}],
      "aliases": ["AOV", "avg order value", "mean order value"]
    },
    {
      "name": "churn_rate",
      "label": "Customer Churn Rate",
      "type": "derived",
      "description": "Fraction of customers with no order in the trailing 90 days",
      "expression": "count(churned_customers) / count(distinct customer_id)",
      "grain": "customer_id",
      "dimensions": ["customer_segment", "region"],
      "filters": [],
      "aliases": ["churn", "customer churn", "attrition rate"]
    },
    {
      "name": "ltv_cac_ratio",
      "label": "LTV:CAC Ratio",
      "type": "derived",
      "description": "Customer Lifetime Value divided by Customer Acquisition Cost; viability threshold = 3.0",
      "expression": "customer_lifetime_value / customer_acquisition_cost",
      "grain": "customer_id",
      "dimensions": ["acquisition_channel", "customer_segment"],
      "filters": [],
      "aliases": ["LTV to CAC", "ltv cac", "value acquisition ratio"]
    },
    {
      "name": "new_customer_count",
      "label": "New Customer Count",
      "type": "simple",
      "description": "Customers placing their first-ever order within the period",
      "expression": "count(distinct customer_id) filter (where is_first_order = true)",
      "grain": "customer_id",
      "dimensions": ["region", "acquisition_channel", "order_date"],
      "filters": [{"field": "is_first_order", "operator": "=", "value": "true"}],
      "aliases": ["new customers", "first-time buyers", "new buyers"]
    },
    {
      "name": "refund_rate",
      "label": "Refund Rate",
      "type": "derived",
      "description": "Fraction of orders that result in a refund",
      "expression": "count(refunded_orders) / count(distinct order_id)",
      "grain": "order_id",
      "dimensions": ["region", "product_category", "order_date"],
      "filters": [],
      "aliases": ["return rate", "refunds", "reversal rate"]
    }
  ],
  "nl_queries": [
    {
      "id": "q001",
      "query": "What is total revenue by region this quarter?",
      "governed_metric": "total_revenue",
      "expected_dimensions": ["region"],
      "expected_time_grain": "quarter",
      "valid_dimension_values": ["region"],
      "invalid_approximation": "gross sales"
    },
    {
      "id": "q002",
      "query": "Show me LTV by customer segment",
      "governed_metric": "customer_lifetime_value",
      "expected_dimensions": ["customer_segment"],
      "expected_time_grain": null,
      "valid_dimension_values": ["customer_segment"],
      "invalid_approximation": "average revenue per user"
    },
    {
      "id": "q003",
      "query": "How many orders were placed last month?",
      "governed_metric": "order_count",
      "expected_dimensions": [],
      "expected_time_grain": "month",
      "valid_dimension_values": [],
      "invalid_approximation": "transaction count"
    },
    {
      "id": "q004",
      "query": "What is the AOV for the enterprise segment in Q3?",
      "governed_metric": "average_order_value",
      "expected_dimensions": ["customer_segment"],
      "expected_time_grain": "quarter",
      "valid_dimension_values": ["customer_segment"],
      "invalid_approximation": "mean purchase value"
    },
    {
      "id": "q005",
      "query": "What is our churn rate for enterprise customers this year?",
      "governed_metric": "churn_rate",
      "expected_dimensions": ["customer_segment"],
      "expected_time_grain": "year",
      "valid_dimension_values": ["customer_segment"],
      "invalid_approximation": "customer loss rate"
    },
    {
      "id": "q006",
      "query": "Is the LTV to CAC ratio above 3 for the paid channel?",
      "governed_metric": "ltv_cac_ratio",
      "expected_dimensions": ["acquisition_channel"],
      "expected_time_grain": null,
      "valid_dimension_values": ["acquisition_channel"],
      "invalid_approximation": "customer value over acquisition cost"
    },
    {
      "id": "q007",
      "query": "How many new customers did we acquire via organic in January?",
      "governed_metric": "new_customer_count",
      "expected_dimensions": ["acquisition_channel"],
      "expected_time_grain": "month",
      "valid_dimension_values": ["acquisition_channel"],
      "invalid_approximation": "first-time buyer count"
    },
    {
      "id": "q008",
      "query": "What is the refund rate for the APAC region last quarter?",
      "governed_metric": "refund_rate",
      "expected_dimensions": ["region"],
      "expected_time_grain": "quarter",
      "valid_dimension_values": ["region"],
      "invalid_approximation": "return percentage"
    },
    {
      "id": "q009",
      "query": "Revenue breakdown by payment method for completed orders",
      "governed_metric": "total_revenue",
      "expected_dimensions": ["payment_method"],
      "expected_time_grain": null,
      "valid_dimension_values": ["payment_method"],
      "invalid_approximation": "sales by payment type"
    },
    {
      "id": "q010",
      "query": "Customer lifetime value for the EMEA region",
      "governed_metric": "customer_lifetime_value",
      "expected_dimensions": ["region"],
      "expected_time_grain": null,
      "valid_dimension_values": ["region"],
      "invalid_approximation": "EMEA customer spend"
    },
    {
      "id": "q011",
      "query": "Weekly order count trend for North America",
      "governed_metric": "order_count",
      "expected_dimensions": ["region"],
      "expected_time_grain": "week",
      "valid_dimension_values": ["region"],
      "invalid_approximation": "weekly purchases"
    },
    {
      "id": "q012",
      "query": "What percentage of customers churned from the SMB segment?",
      "governed_metric": "churn_rate",
      "expected_dimensions": ["customer_segment"],
      "expected_time_grain": null,
      "valid_dimension_values": ["customer_segment"],
      "invalid_approximation": "SMB customer loss"
    },
    {
      "id": "q013",
      "query": "Average order value by product category this month",
      "governed_metric": "average_order_value",
      "expected_dimensions": ["product_category"],
      "expected_time_grain": "month",
      "valid_dimension_values": ["product_category"],
      "invalid_approximation": "mean basket size"
    },
    {
      "id": "q014",
      "query": "New customers from the referral channel in H1",
      "governed_metric": "new_customer_count",
      "expected_dimensions": ["acquisition_channel"],
      "expected_time_grain": "half_year",
      "valid_dimension_values": ["acquisition_channel"],
      "invalid_approximation": "referred new buyers"
    },
    {
      "id": "q015",
      "query": "Is our LTV:CAC above the viability threshold of 3?",
      "governed_metric": "ltv_cac_ratio",
      "expected_dimensions": [],
      "expected_time_grain": null,
      "policy_threshold": 3.0,
      "valid_dimension_values": [],
      "invalid_approximation": "customer value ratio"
    }
  ],
  "dimension_conformance_tests": [
    {
      "id": "dc001",
      "metric": "total_revenue",
      "query_dimension": "region",
      "is_valid": true,
      "reason": "region is declared in metric dimensions list"
    },
    {
      "id": "dc002",
      "metric": "total_revenue",
      "query_dimension": "salesperson_id",
      "is_valid": false,
      "reason": "salesperson_id is not declared in metric dimensions list"
    },
    {
      "id": "dc003",
      "metric": "customer_lifetime_value",
      "query_dimension": "order_id",
      "is_valid": false,
      "reason": "grain is customer_id; slicing by order_id violates grain constraint"
    },
    {
      "id": "dc004",
      "metric": "churn_rate",
      "query_dimension": "customer_segment",
      "is_valid": true,
      "reason": "customer_segment is declared in metric dimensions list"
    },
    {
      "id": "dc005",
      "metric": "order_count",
      "query_dimension": "payment_method",
      "is_valid": true,
      "reason": "payment_method is declared in metric dimensions list"
    },
    {
      "id": "dc006",
      "metric": "ltv_cac_ratio",
      "query_dimension": "region",
      "is_valid": false,
      "reason": "region not in ltv_cac_ratio dimensions; use acquisition_channel or customer_segment"
    },
    {
      "id": "dc007",
      "metric": "refund_rate",
      "query_dimension": "product_category",
      "is_valid": true,
      "reason": "product_category is declared in metric dimensions list"
    },
    {
      "id": "dc008",
      "metric": "new_customer_count",
      "query_dimension": "order_id",
      "is_valid": false,
      "reason": "grain is customer_id; order_id violates grain constraint"
    }
  ]
}
